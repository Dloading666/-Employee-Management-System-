<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.com.eams.mapper.PostLevelMapper">
    <resultMap id="PostLevelResultMap" type="edu.com.eams.domain.PostLevel">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="level" column="level"/>
        <result property="salary" column="salary"/>
        <result property="sortCode" column="sort_code"/>
        <result property="status" column="status"/>
    </resultMap>

    <select id="findAll" resultMap="PostLevelResultMap">
        SELECT * FROM emp_post_level
    </select>

    <select id="findById" parameterType="long" resultMap="PostLevelResultMap">
        SELECT * FROM emp_post_level WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="edu.com.eams.domain.PostLevel">
        INSERT INTO emp_post_level(name, level, salary, sort_code, status)
        VALUES(#{name}, #{level}, #{salary}, #{sortCode}, #{status})
    </insert>

    <update id="update" parameterType="edu.com.eams.domain.PostLevel">
        UPDATE emp_post_level SET
            name=#{name}, level=#{level}, salary=#{salary}, sort_code=#{sortCode}, status=#{status}
        WHERE id=#{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM emp_post_level WHERE id=#{id}
    </delete>

    <select id="findByCondition" resultMap="PostLevelResultMap">
        SELECT * FROM emp_post_level
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        LIMIT #{start}, #{size}
    </select>

    <select id="countByCondition" resultType="int">
        SELECT COUNT(*) FROM emp_post_level
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
    </select>
</mapper> 